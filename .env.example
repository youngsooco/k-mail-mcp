# 한국 메일 MCP 서버 설정

# ─── 메일 서비스 선택 ───────────────────────────────────────────────────────
# naver | daum | gmail
MAIL_SERVICE=naver

# ─── 네이버 메일 설정 ────────────────────────────────────────────────────────
# MAIL_USER=your-id@naver.com
# MAIL_PASS=앱_비밀번호   ← 네이버 계정 보안 > 애플리케이션 비밀번호에서 발급

# ─── 다음(카카오) 메일 설정 ──────────────────────────────────────────────────
# MAIL_USER=your-id@daum.net
# MAIL_PASS=카카오_앱_비밀번호   ← 카카오 계정 > 보안 > 앱 비밀번호에서 발급

MAIL_USER=
MAIL_PASS=
